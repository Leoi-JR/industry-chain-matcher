# ── LLM API (used in threshold calibration: calibrate_thresholds_llm.py) ──
# Base URL of your OpenAI-compatible LLM service (with or without /chat/completions)
LLM_API_URL=http://localhost:8000/v1

# API authentication key
LLM_API_KEY=sk-your-api-key-here

# Model name to use for threshold calibration
LLM_MODEL_NAME=deepseek-r1

# ── Embedding model (used in embedding_code/ pipeline) ────────────────────
# Local path to the embedding model (e.g. Qwen3-Embedding-8B)
# Requires a CUDA-capable GPU (flash_attention_2 + float16)
EMBEDDING_MODEL_PATH=/path/to/your/embedding-model
